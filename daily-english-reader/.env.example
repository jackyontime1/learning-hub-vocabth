# Safety: this project has no paid provider path.
FREE_ONLY=1

# Free news sources. Missing keys simply skip that provider.
CURRENTS_API_KEY=
GUARDIAN_API_KEY=
NASA_API_KEY=DEMO_KEY

# Free image source. Openverse and Wikimedia Commons need no key.
UNSPLASH_ACCESS_KEY=

# Optional free local image generation. Example: Stable Diffusion WebUI started with --api.
LOCAL_IMAGE_API_URL=
LOCAL_IMAGE_STEPS=20
LOCAL_IMAGE_TIMEOUT=180

# Self-hosted translation.
LIBRETRANSLATE_URL=http://127.0.0.1:5000
LIBRETRANSLATE_API_KEY=

# Optional local LLM. Leave empty to use summa + deterministic heuristics.
OLLAMA_URL=
OLLAMA_MODEL=llama3.2:3b

RETENTION_DAYS=30
REQUEST_TIMEOUT=25

# Internal soft limits, intentionally below public provider quotas.
CURRENTS_DAILY_LIMIT=2
GUARDIAN_DAILY_LIMIT=2
NASA_DAILY_LIMIT=2
NWS_DAILY_LIMIT=2
USGS_DAILY_LIMIT=2
ARXIV_DAILY_LIMIT=2
UNSPLASH_DAILY_LIMIT=10
OPENVERSE_DAILY_LIMIT=10
COMMONS_DAILY_LIMIT=10

# Offline smoke test.
DEMO_MODE=0
SKIP_AUDIO=0
